# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Market Data WebSocket (broker real-time feed, same port as API)
VITE_MARKET_WS_URL=ws://localhost:3000/ws/market

# OAuth Configuration (Optional)
# VITE_GOOGLE_CLIENT_ID=your-google-client-id
# VITE_APPLE_CLIENT_ID=your-apple-client-id

# AES-256-GCM payload encryption key (MUST match backend ENCRYPTION_KEY)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VITE_ENCRYPTION_KEY=your_32_plus_char_encryption_key_here

# Environment
VITE_ENV=development
