# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# InvestBot AI Chatbot (Claude API)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6

# AES-256-GCM payload encryption (MUST match frontend VITE_ENCRYPTION_KEY)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_plus_char_encryption_key_here

# Database Configuration (PostgreSQL)
# Option 1: Direct connection string (Supabase, Neon, etc.) – SSL enabled automatically
# If password contains @ or :, URL-encode them (@ → %40, : → %3A)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxx.supabase.co:5432/postgres

# Option 2: Separate vars (for local or when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finsieve_db
DB_USER=finsieve_user
DB_PASSWORD=your_secure_password_here

# Set DB_SSL=true when using cloud Postgres with separate vars (e.g. Supabase)
# DB_SSL=true

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_make_it_very_long_and_secure
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_also_very_long_and_secure
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (Optional - for later)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@finsieve.com

# External API Keys (for market data)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
FINNHUB_API_KEY=your_finnhub_key
COINGECKO_API_KEY=your_coingecko_key

# ── Broker APIs ──────────────────────────────────────────────────────────────
# Upstox Developer API (https://developer.upstox.com)
# Create app → get client_id + client_secret → set redirect_uri
UPSTOX_CLIENT_ID=your_upstox_client_id
UPSTOX_CLIENT_SECRET=your_upstox_client_secret
UPSTOX_REDIRECT_URI=http://localhost:3000/api/v1/broker/upstox/callback

# Zerodha Kite Connect (https://developers.kite.trade)
# Register app → get api_key + api_secret
ZERODHA_API_KEY=your_zerodha_api_key
ZERODHA_API_SECRET=your_zerodha_api_secret
# redirect_uri must match: http://localhost:3000/api/v1/broker/zerodha/callback

# Angel One SmartAPI (https://smartapi.angelbroking.com)
# Create app → get api_key; use your Angel One demat credentials for login
ANGELONE_API_KEY=your_angelone_api_key
ANGELONE_CLIENT_ID=your_angelone_client_id       # Demat account ID
ANGELONE_CLIENT_PIN=your_angelone_mpin           # 4-digit MPIN
ANGELONE_TOTP_SECRET=your_totp_base32_secret     # From Angel One app QR code

# Redis Configuration (Optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=info
